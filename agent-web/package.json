{
  "name": "agent-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "LiveKit Cloud voice agent web frontend (React + Session API) with an Express token server.",
  "scripts": {
    "dev": "concurrently -k -n server,web -c green,cyan \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "node --watch server/index.mjs",
    "dev:web": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "start": "cross-env NODE_ENV=production node server/index.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "@livekit/components-react": "^2.9.6",
    "@livekit/components-styles": "^1.1.6",
    "express": "^4.21.2",
    "livekit-client": "^2.11.5",
    "livekit-server-sdk": "^2.13.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.17.10",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "playwright": "^1.61.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  }
}
