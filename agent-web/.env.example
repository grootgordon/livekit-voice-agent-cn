# ─────────────────────────────────────────────────────────────
# agent-web 项目本地配置
#
# 注意：LiveKit 凭据(LIVEKIT_URL/API_KEY/API_SECRET)已统一放到
#       仓库根的 .livekit.env，由 token server 启动时按
#       LIVEKIT_PROFILE(cloud|local)读取。切换 Cloud⇄本地改根目录
#       .livekit.env 即可，**不要**在本文件里写 LIVEKIT_*。
# ─────────────────────────────────────────────────────────────

# Token 服务监听端口（开发时 Vite 会把 /api 代理到这里）
PORT=8787

# ─────────────────────────────────────────────────────────────
# 以下 VITE_ 开头的变量会被 Vite 注入到前端 import.meta.env
# ─────────────────────────────────────────────────────────────

# 默认 agent 名：必须与你部署的 agent 的 agentName 一致，才会被派发进房间
VITE_AGENT_NAME=my-agent

# 可选：覆盖 token 接口地址。默认相对路径 "/api/token"
# 开发：Vite 代理到上面的 PORT；生产：Express 同源托管
# VITE_TOKEN_ENDPOINT=/api/token
