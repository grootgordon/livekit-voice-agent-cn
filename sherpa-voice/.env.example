# sherpa-voice 配置 —— 复制为 .env 并按需修改(.env 已 gitignore)

# 服务端口(避开 agent-web 8787 / livekit 7880 / kokoro 8880)
PORT=8001

# 模型目录(默认 theresa 22kHz 原神音色; 软链到 kokoro 下模型; 可换 models/aishell3)
MODEL_DIR=models/theresa

# ONNX 推理线程数(i7-4770HQ 4C8T, 4 较优)
NUM_THREADS=4

# 目标采样率: LiveKit openai.TTS 固定 24000, 服务端必须输出 24kHz PCM
TARGET_SAMPLE_RATE=24000

# aishell3 多说话人 sid (0-173), 0 是默认女声
SPEAKER_ID=0

# 音量归一化: theresa 峰值~0.66 已够响(gain=1.0 即不放大); 换 aishell3(峰值0.11)设 gain=8.0
NORMALIZE_VOLUME=true
NORMALIZE_GAIN=1.0

# 语速 (1.0 = 正常)
SPEED=1.0
