# ─────────────────────────────────────────────────────────────
# agent-py 模型密钥(国内生态)
# 复制为 .env.local(.gitignore 已忽略)并填入真实值。
#
# 注意:LiveKit 传输层(URL/KEY/SECRET)不在本文件,
#       统一在仓库根 .livekit.env 由 LIVEKIT_PROFILE(cloud|local)决定。
# ─────────────────────────────────────────────────────────────

# DeepSeek(LLM)—— https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# MiniMax(TTS)
# 国内站: https://platform.minimaxi.com  → key 配 https://api.minimaxi.com
# 国际站: https://platform.minimax.io    → key 配 https://api.minimax.io
# ⚠️ 国内/国际 key 不通用,域名要与 key 匹配
MINIMAX_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx
MINIMAX_BASE_URL=https://api.minimaxi.com
# 可选:指定音色(留空用插件默认 socialmedia_female_2_v1)
# MINIMAX_VOICE=

# 火山引擎「豆包大模型流式语音识别」(新版控制台 API Key 接入)
# 控制台 → 语音技术(新版)→ API Keys: https://console.volcengine.com/speech/new/setting/apikeys
VOLC_ASR_API_KEY=你的API-Key              # X-Api-Key
# 资源 ID:1.0 小时版=volc.bigasr.sauc.duration;2.0 小时版=volc.seedasr.sauc.duration
VOLC_ASR_RESOURCE_ID=volc.bigasr.sauc.duration

# ── TTS provider ──────────────────────────────────────────────────────────────
# sherpa(默认, 本地): 走 ../sherpa-voice 的 OpenAI 兼容服务(零成本, 纯中文;默认 theresa 22kHz 音色)
# minimax(云端): 需有效 MINIMAX_API_KEY(欠费时切回 sherpa)
TTS_PROVIDER=sherpa
SHERPA_VOICE_URL=http://localhost:8001/v1
SHERPA_VOICE=0          # theresa 单说话人留 0;换 aishell3 则为 speaker sid(0-173)
