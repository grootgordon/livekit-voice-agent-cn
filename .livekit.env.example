# ─────────────────────────────────────────────────────────────────────────────
# LiveKit 传输层切换配置 —— 示例文件
# 复制为 .livekit.env(注意没有 .example 后缀)并填入你的值。.livekit.env 已 gitignore。
#
# agent-web(token server)和 agent-node(agent)启动时都会向上查找 .livekit.env,
# 根据 LIVEKIT_PROFILE 把对应预设写进标准环境变量(LIVEKIT_URL/KEY/SECRET)。
# ─────────────────────────────────────────────────────────────────────────────

# 选一个:cloud | local
LIVEKIT_PROFILE=cloud

# ── Cloud 预设:从 https://cloud.livekit.io → 项目 → Settings 获取 ──
LIVEKIT_URL_CLOUD=wss://your-project.livekit.cloud
LIVEKIT_API_KEY_CLOUD=APIxxxxxxxxxxxxxxxx
LIVEKIT_API_SECRET_CLOUD=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── 本地预设:本仓库 livekit/ 源码 `livekit-server --dev` 自带 ──
LIVEKIT_URL_LOCAL=ws://localhost:7880
LIVEKIT_API_KEY_LOCAL=devkey
LIVEKIT_API_SECRET_LOCAL=secret
